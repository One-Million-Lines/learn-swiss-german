    "id": "k-to-ch",
    "title": "K → Ch Shift",
    "description": "One of the most distinctive features of Swiss German. Initial 'k' becomes 'ch'.",
    "examples": [
      {
        "german": "Kopf",
        "swissGerman": "Chopf",
        "english": "head",

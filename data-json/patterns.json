        "swissGerman": "chaufe",
        "english": "to buy",
        "spanish": "comprar"
      },
      {
        "german": "kochen",
        "swissGerman": "choche",
        "english": "to cook",
        "spanish": "cocinar"
      },
      {
        "german": "kalt",
        "swissGerman": "chalt",
        "english": "cold",
        "spanish": "frío"
